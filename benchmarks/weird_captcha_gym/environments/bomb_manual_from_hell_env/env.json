{
  "id": "weird_captcha_gym.bomb_manual_from_hell_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "A spatial bomb-defusal puzzle built around draggable, rotatable, flippable transparent manual plates.",
  "category": ["visual_puzzle", "captcha_inspired", "computer_use"],
  "authors": ["captcha-bench contributors"],
  "resources": {"cpu": 2, "mem_gb": 4, "gpu": 0, "net": false},
  "observation": [{"type": "rgb_screen", "fps": 10, "resolution": [1280, 720], "inline": false}],
  "action": [{"type": "mouse"}, {"type": "keyboard"}],
  "synchronous": true,
  "step_cycle_ms": 160,
  "recording": {"enable": false, "output_dir": "benchmarks/weird_captcha_gym/environments/bomb_manual_from_hell_env/artifacts"},
  "vnc": {"enable": false, "host_port": 6142, "view_only": false, "password": "password"},
  "security": {"user": "root", "cap_drop": ["ALL"], "privileged": true, "use_systemd": true, "mount_cgroups": true, "cgroupns_host": true, "tmpfs_run": true, "runtime": "sysbox-runc"},
  "mounts": [
    {"source": "benchmarks/weird_captcha_gym/environments/bomb_manual_from_hell_env/scripts", "target": "/workspace/scripts", "mode": "ro"},
    {"source": "benchmarks/weird_captcha_gym/environments/bomb_manual_from_hell_env/tasks", "target": "/workspace/tasks", "mode": "ro"},
    {"source": "benchmarks/weird_captcha_gym/shared_runtime", "target": "/workspace/shared_runtime", "mode": "ro"},
    {"source": "benchmarks/weird_captcha_gym/shared_scripts", "target": "/workspace/shared_scripts", "mode": "ro"}
  ],
  "hooks": {"pre_start": "/workspace/scripts/install_puzzle_runtime.sh", "post_start": "/workspace/scripts/setup_puzzle_runtime.sh"},
  "tags": ["linux", "browser", "visual-puzzle", "weird-captcha", "spatial-registration", "layered-occlusion", "irreversible-action"]
}
