{
  "id": "weird_captcha_gym.gravity_room_freight_env@0.1",
  "version": "0.1",
  "base": "ubuntu-gnome-systemd_highres",
  "description": "Rotate an entire chamber and let a physical freight capsule settle through three ordered airlocks into its dock.",
  "category": [
    "visual_puzzle",
    "captcha_inspired",
    "computer_use"
  ],
  "authors": [
    "captcha-bench contributors"
  ],
  "resources": {
    "cpu": 2,
    "mem_gb": 4,
    "gpu": 0,
    "net": false
  },
  "observation": [
    {
      "type": "rgb_screen",
      "fps": 10,
      "resolution": [
        1280,
        720
      ],
      "inline": false
    }
  ],
  "action": [
    {
      "type": "mouse"
    },
    {
      "type": "keyboard"
    }
  ],
  "synchronous": true,
  "step_cycle_ms": 100,
  "recording": {
    "enable": false,
    "output_dir": "benchmarks/weird_captcha_gym/environments/gravity_room_freight_env/artifacts"
  },
  "vnc": {
    "enable": false,
    "host_port": 6174,
    "view_only": false,
    "password": "password"
  },
  "security": {
    "user": "root",
    "cap_drop": [
      "ALL"
    ],
    "privileged": true,
    "use_systemd": true,
    "mount_cgroups": true,
    "cgroupns_host": true,
    "tmpfs_run": true,
    "runtime": "sysbox-runc"
  },
  "mounts": [
    {
      "source": "benchmarks/weird_captcha_gym/environments/gravity_room_freight_env/scripts",
      "target": "/workspace/scripts",
      "mode": "ro"
    },
    {
      "source": "benchmarks/weird_captcha_gym/environments/gravity_room_freight_env/tasks",
      "target": "/workspace/tasks",
      "mode": "ro"
    },
    {
      "source": "benchmarks/weird_captcha_gym/shared_runtime",
      "target": "/workspace/shared_runtime",
      "mode": "ro"
    },
    {
      "source": "benchmarks/weird_captcha_gym/shared_scripts",
      "target": "/workspace/shared_scripts",
      "mode": "ro"
    }
  ],
  "hooks": {
    "pre_start": "/workspace/scripts/install_puzzle_runtime.sh",
    "post_start": "/workspace/scripts/setup_puzzle_runtime.sh"
  },
  "tags": [
    "linux",
    "browser",
    "visual-puzzle",
    "weird-captcha",
    "gravity_room_freight",
    "gravity-transform",
    "spatial-planning",
    "persistent-state"
  ]
}
